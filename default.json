{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "onboardingPrTitle": "chore(deps): configure renovate",
  "extends": [
    ":semanticCommits",
    "config:recommended",
    ":configMigration",
    ":pinAllExceptPeerDependencies",
    "customManagers:biomeVersions",
    "github>reside-eng/renovate-config:private-npm",
    "github>reside-eng/renovate-config:actions-ci"
  ],
  "ignorePresets": [":prHourlyLimit2"],
  "timezone": "America/Los_Angeles",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 50,
  "platformAutomerge": true,
  "platformCommit": "enabled",
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "rebaseWhen": "conflicted",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "extends": ["schedule:weekly"]
  },
  "packageRules": [
    {
      "description": "Keep GitHub Actions tag refs floating (override :pinAllExceptPeerDependencies for the github-actions manager). Renovate v43.138.0 (2026-04-21) started honouring rangeStrategy:pin for github-actions, which caused it to pin floating major tags like @v11 to specific patch tags (@v11.15.1). Combined with our auto-merge rules that accept update type 'pin', this produced an immortal auto-merged pin-dependencies PR per repo, and an infinite release loop on workflow-templates via its own self-references. SHA pinning of third-party actions is still enforced per-repo via pinDigests:true.",
      "matchManagers": ["github-actions"],
      "rangeStrategy": "replace"
    },
    { "matchDatasources": ["docker"], "labels": ["docker-deps"] },
    {
      "description": "Lock redis to 6.x to match our cloud instances",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["redis"],
      "allowedVersions": "6.x"
    },
    {
      "description": "Group Side Inc. lint configs",
      "matchSourceUrlPrefixes": ["https://github.com/reside-eng/lint-config"],
      "groupName": "Side lint config",
      "groupSlug": "side-lint-config"
    },
    {
      "description": "Ignore Side Inc. private docker image updates (registry auth not yet setup) [PLAT-1660]",
      "matchPackagePrefixes": ["us-central1-docker.pkg.dev/reside-prod"],
      "matchManagers": ["dockerfile"]
    },
    {
      "description": "Require stability of NPM dependencies which are not managed by Side Inc., Google or another trusted organization (since they can be unpublished)",
      "matchDatasources": ["npm"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "excludePackagePatterns": ["^@side", "^@google", "^google-", "^@datadog"],
      "excludePackageNames": [
        "next",
        "react",
        "react-dom",
        "@yarnpkg/cli",
        "npm",
        "node"
      ],
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Auto-merge minor/patch/pin/digest updates for high-confidence GitHub Action publishers (trusted vendor orgs only). Other third-party actions require manual review.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchPackageNames": [
        "/^actions\\//",
        "/^github\\//",
        "/^google-github-actions\\//",
        "/^docker\\//",
        "/^hashicorp\\//",
        "/^anthropics\\//",
        "/^slackapi\\//",
        "/^denoland\\//",
        "/^renovatebot\\//",
        "/^cypress-io\\//"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Auto-merge minor/patch/digest updates for high-confidence Docker image publishers (official Docker library + trusted vendor orgs). Other images require manual review.",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "matchPackageNames": [
        "node",
        "python",
        "golang",
        "ruby",
        "rust",
        "java",
        "openjdk",
        "postgres",
        "mysql",
        "mariadb",
        "mongo",
        "redis",
        "memcached",
        "alpine",
        "debian",
        "ubuntu",
        "busybox",
        "nginx",
        "/^google\\//",
        "/^gcr\\.io\\//",
        "/^us-docker\\.pkg\\.dev\\/google\\//",
        "/^ghcr\\.io\\/actions\\//",
        "/^hashicorp\\//",
        "/^datadog\\//",
        "/^grafana\\//",
        "/^amazon\\//"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Group and auto-merge non-major NodeJS dependencies on weekday mornings",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchDepNames": ["node", "@types/node"],
      "schedule": ["after 5am and before 4pm every weekday"],
      "groupName": "Non-major NodeJS deps",
      "groupSlug": "non-major-nodejs-deps",
      "automerge": true
    },
    {
      "description": "Group and auto-merge non-major Yarn dependencies on weekday mornings",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchDepNames": ["yarn"],
      "schedule": ["after 5am and before 4pm every weekday"],
      "groupName": "Non-Major packager deps",
      "groupSlug": "non-major-packager-deps",
      "automerge": true
    },
    {
      "description": "Skip faker updates (since it is no longer supported)",
      "matchPackageNames": ["faker", "@types/faker"],
      "enabled": false
    },
    {
      "description": "node-config library and types",
      "matchPackageNames": ["config", "@types/config"],
      "groupName": "Node config and types",
      "groupSlug": "node-config"
    },
    {
      "description": "Group size-limit packages",
      "matchPackageNames": ["size-limit"],
      "matchPackagePrefixes": ["@size-limit"],
      "groupName": "Size limit packages",
      "groupSlug": "size-limit"
    },
    {
      "description": "Group Fastify and Fastify scoped packages",
      "matchPackageNames": ["fastify", "fastify-plugin"],
      "matchPackagePrefixes": ["@fastify/", "^@side/fastify-"],
      "groupName": "Fastify packages",
      "groupSlug": "fastify-packages"
    },
    {
      "description": "Skip config updates (breaking change at 3.3.8)",
      "matchPackageNames": ["config"],
      "allowedVersions": "<=3.3.7"
    },
    {
      "description": "Prevent upgrade of Eslint to v9 until updates are made",
      "matchPackageNames": ["eslint"],
      "allowedVersions": "^8"
    },
    {
      "description": "Prevent upgrade of dd-trace from v5.41.1 to latest (temporarily). Also disable auto-merge and wait for 30 days before creating the PR.",
      "matchPackageNames": ["dd-trace"],
      "allowedVersions": "<=5.81.0",
      "automerge": false,
      "minimumReleaseAge": "30 days",
      "prBodyNotes": [
        "Please verify that there is no reported issues for the current version update: https://github.com/DataDog/dd-trace-js/issues"
      ]
    },
    {
      "description": "Prevent upgrade to axios 1.14.x (security compromised)",
      "matchPackageNames": ["axios"],
      "allowedVersions": "<=1.14.0"
    },
    {
      "description": "Prevent upgrade to @side/fastify-identity-auth 2.0.20 (accidental minor, should have been major)",
      "matchPackageNames": ["@side/fastify-identity-auth"],
      "allowedVersions": "!/^2\\.0\\.20$/"
    },
    {
      "description": "Prevent upgrade to @side/identity-token 5.1.24 (accidental minor, should have been major)",
      "matchPackageNames": ["@side/identity-token"],
      "allowedVersions": "!/^5\\.1\\.24$/"
    },
    {
      "description": "Disable auto-merge for all major releases",
      "matchUpdateTypes": ["major"],
      "rebaseWhen": "never",
      "automerge": false
    }
  ]
}
